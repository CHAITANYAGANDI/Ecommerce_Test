PORT=7001
NODE_ENV=development

# MongoDB connection string (read by Models/db.js as process.env.MONGO_CONN).
MONGO_CONN=mongodb://localhost:27017/ecommerce

# Secret used to sign the userToken / adminToken / pendingAuth / refresh JWTs.
JWT_SECRET=replace-with-a-long-random-string

# Comma-separated list of allowed browser origins for CORS.
# Includes the source-branded mock storefronts because the gateway forwards
# the original Origin header to upstream services — when Amazon's checkout
# page (port 8000) calls /checkout/intent through the gateway, this service
# still sees Origin: http://localhost:8000 and CORS-rejects it unless listed.
CORS_ORIGINS=http://localhost:3001,http://localhost:8000,http://127.0.0.1:8001,http://localhost:8001

# Public URL of the React storefront (used for Google OAuth redirect).
CLIENT_URL=http://localhost:3001

# Internal URL of the Auth/server (used by admin client-authorization flow).
AUTH_SERVER_URL=http://localhost:5000

# Internal URL of the APIGateway. Used to call DELETE /internal/token-cache/:apiName
# when an admin deletes a credential, so the gateway evicts the cached token
# instead of continuing to inject a now-invalid one. API_GATEWAY_URL is the
# canonical name; GATEWAY_URL is read as a fallback for backward compat.
API_GATEWAY_URL=http://localhost:7000

# Shared secret for service-to-service calls (sent as x-internal-auth header).
# Used by:
#  - Middlewares/authCallback.js (verifies the Auth-server → Users callback)
#  - Controllers/DeleteClientCredController.js (gateway token-cache eviction)
#  - Controllers/InternalPriceDropController.js (gateway → Users price-drop notifier)
# Must match the INTERNAL_AUTH_SECRET set in Auth/server and APIGateway.
INTERNAL_AUTH_SECRET=replace-with-a-long-random-string

# Google OAuth (Sign in with Google). All three must be set together,
# or all three left empty to disable Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:7001/auth/google/callback

# OTP + password-reset + price-alert mailer (Brevo HTTPS API).
# Required in production. We use Brevo because Render's free tier blocks
# outbound SMTP (so nodemailer/Gmail can't reach the wire) AND Brevo's
# free tier (300/day) allows single-sender verification — verify one
# email address by clicking a link, no domain or DNS records needed.
#
# Setup:
#   1. Sign up at https://brevo.com (free, no card).
#   2. Settings → Senders & IP → Senders → "Add a sender". Enter your
#      personal email (e.g. chaitanyagandi2000@gmail.com), click the
#      confirmation link Brevo emails you.
#   3. SMTP & API → API Keys → Generate a new API key. Paste below.
#   4. Set MAIL_FROM to "Display Name <verified-email>". The email part
#      MUST match the address you verified in step 2 or Brevo rejects
#      the send with "sender_not_valid".
BREVO_API_KEY=
MAIL_FROM=Trendy Treasures <your-verified-email@gmail.com>

# Rate-limit tunables (optional — sensible defaults if omitted).
# Per-IP request budget across all Users routes (default 120/min). The
# /internal/* paths are exempt (gated by INTERNAL_AUTH_SECRET instead).
RATE_LIMIT_PER_MIN=120
# Per-IP budget for /auth/login, /auth/signup, /auth/verifyotp,
# /admin/login, /recovery (default 30 per 15 min).
AUTH_RATE_LIMIT_PER_15M=30

# Trust-proxy setting for express-rate-limit. `loopback` is correct for
# local dev. In prod set to the number of upstream proxies (Render/Heroku
# is typically 1). NEVER set to `true` — it lets clients spoof X-Forwarded-For.
TRUST_PROXY=loopback

# OpenAI API key used by /ai/price-advice and /ai/product-qa.
# - Price advice reads from price_snapshots and returns a 1–2 sentence
#   buy-now/wait recommendation per product. Result cached 6h per product.
# - Product Q&A answers shopper questions grounded in product metadata
#   the client passes in. No caching (questions vary).
# If unset, both endpoints return 503 "AI unavailable" and the UI
# widgets gracefully render an "AI commentary disabled" state.
OPENAI_API_KEY=
# Optional — model override. Default: gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini
