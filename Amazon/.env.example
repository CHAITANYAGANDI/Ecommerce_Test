PORT=8000

# MongoDB connection string (read as process.env.MONGO_CONN).
# Amazon owns its own database — products, orders, customers, addresses,
# payments are isolated from the storefront/aggregator data.
MONGO_CONN=mongodb://localhost:27017/amazon

# Comma-separated list of allowed browser origins for CORS.
# Must include this service's own origin (http://localhost:8000) because the
# checkout page hosted here makes fetch POSTs to /payments/create-intent and
# /orders/place — browsers still send an Origin header on same-origin POSTs
# and the cors() middleware rejects anything not in the allowlist.
CORS_ORIGINS=http://localhost:3001,http://localhost:8000

# Secret used to verify the productsauthorization JWT.
# Read as process.env.SECRET in Amazon/Middlewares/Authorization.js. The same
# variable name is used in Walmart (read by Walmart/Middlewares/authorization.py).
# Both must equal Auth/server's JWT_PROVIDER_SECRET (or its fallback JWT_SECRET)
# — that's the secret used to sign the token in Auth/server/utils/tokens.js.
SECRET=replace-with-a-long-random-string

# Auth server used for active-jti introspection. The middleware calls
# GET ${AUTH_SERVER_URL}/auth/token/active/:clientId to learn the currently-
# active jti for an incoming token's client_id and reject tokens whose jti
# doesn't match (i.e. tokens superseded by a more recent re-auth/refresh).
AUTH_SERVER_URL=http://localhost:5000

# Gateway URL used by Amazon checkout to fetch trusted referral details and
# mark checkout intents completed after an order is placed. In Docker use
# http://gateway:7000; in local non-Docker dev use http://localhost:7000.
TT_GATEWAY_URL=http://localhost:7000

# Shared secret for service-to-service calls (sent as x-internal-auth header).
# Must match Auth/server's INTERNAL_AUTH_SECRET. Without it, the auth server
# rejects introspection requests with 403 and superseded-token detection
# silently breaks.
INTERNAL_AUTH_SECRET=replace-with-a-long-random-string

# How long (ms) to cache an active_jti lookup per client_id. Lower = faster
# revocation propagation, higher = fewer auth-server hits. 30s default.
AUTH_INTROSPECT_CACHE_TTL_MS=30000

# Rate-limit tunables (optional — sensible defaults if omitted).
# Per-IP request budget across all Amazon routes (default 120/min).
RATE_LIMIT_PER_MIN=120
# Per-IP budget for /payments/* (default 20/min). Tighter because each call
# round-trips Stripe and costs money on abuse.
PAYMENTS_RATE_LIMIT_PER_MIN=20

# Trust-proxy setting for express-rate-limit. `loopback` is correct for
# local dev. In prod set to the number of upstream proxies (Render/Heroku
# is typically 1). NEVER set to `true` — it lets clients spoof X-Forwarded-For.
TRUST_PROXY=loopback

# Stripe API keys (test mode). Get them from https://dashboard.stripe.com/test/apikeys
# - STRIPE_SECRET_KEY: server-side, never exposed to the browser. Used to create + verify PaymentIntents.
# - STRIPE_PUBLISHABLE_KEY: client-side, safe to ship to the browser. Used to mount Stripe Elements.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
