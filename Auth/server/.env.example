PORT=5000
NODE_ENV=development

# MongoDB connection string (read as process.env.MONGO_CONN).
# Auth/server runs on its OWN database so its `clients` and `credentials`
# collections are isolated from the storefront's data.
MONGO_CONN=mongodb://localhost:27017/auth

# HMAC secret used to sign user-session JWTs (authToken / authRefreshToken).
# Must be >=32 chars in production. Rotate periodically — rotation
# instantly invalidates every live session.
JWT_SECRET=replace-with-a-long-random-string

# Separate HMAC secret used to sign provider-access JWTs (the ones issued
# from /authorize and /token/refresh and consumed by Amazon/Walmart
# middleware). Kept distinct from JWT_SECRET so a leak of one trust
# domain doesn't contaminate the other.
#
# IMPORTANT: if this is unset, utils/tokens.js silently falls back to
# JWT_SECRET — boot succeeds but the two trust domains collapse into one.
# Always set this to a DIFFERENT value from JWT_SECRET in production.
JWT_PROVIDER_SECRET=replace-with-a-different-long-random-string

# Shared secret used on the /token/active/:clientId introspection endpoint
# (downstream Amazon/Walmart middleware passes it in x-internal-auth) and
# the redirect_uri callback to the Users service. REQUIRED in production —
# the introspection endpoint fails closed if this is unset.
INTERNAL_AUTH_SECRET=replace-with-a-long-random-string

# Comma-separated list of allowed browser origins for CORS.
# - 3002: Auth/client React app (per its package.json "start" script).
# - 3001: main storefront (admin AuthRequest flow redirects through here).
# - 5000: same-origin form POST from the EJS-rendered /auth/client/login page.
CORS_ORIGINS=http://localhost:3002,http://localhost:3001,http://localhost:5000

# Comma-separated list of extra origins permitted in the Content-Security-
# Policy `form-action` directive (used in production only). The EJS login
# page POSTs back to its own origin by default; add any cross-origin form
# targets here. Leave blank for local dev.
FORM_ACTION_ORIGINS=

# Where the React client lives. The Google OAuth callback redirects back
# here once a session has been minted.
AUTH_CLIENT_URL=http://localhost:3002

# RS256 public key for the APIGateway → /auth/token/refresh flow.
# The gateway holds the matching PRIVATE key and signs assertion JWTs;
# this server verifies them with the PUBLIC key below. If unset, the
# /auth/token/refresh endpoint returns 503 and provider-JWT refresh
# stops working — but the rest of Auth still boots.
#
# Paste the public half of the keypair you generated for the gateway
# (see APIGateway/.env.example for the openssl/node one-liner).
GATEWAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...REPLACE-WITH-YOUR-OWN-KEY...AQAB\n-----END PUBLIC KEY-----\n"

# Comma-separated list of `iss` values we trust on incoming assertion JWTs.
# Add a new issuer here when wiring a new internal service. (Default: apigateway)
TRUSTED_ISSUERS=apigateway

# How long provider JWTs live before they need to be refreshed. 1h matches
# Amazon SP-API's documented access token TTL — short enough that a leaked
# token expires before most attackers can act on it, long enough that the
# auto-refresh path runs at most ~24×/day per provider. (Default: 30d)
CLIENT_TOKEN_TTL=1h

# Optional — Google OAuth (Sign in with Google). All three must be set
# together, or all three left unset to disable Google login.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Password-reset + signup OTP mailer (Brevo HTTPS API).
# Required in production — both /register and /recovery fail closed
# if either is unset. We use Brevo because Render's free tier blocks
# outbound SMTP (so nodemailer/Gmail can't reach the wire) AND Brevo's
# free tier (300/day) allows single-sender verification — verify one
# email address by clicking a link, no domain or DNS records needed.
#
# Setup:
#   1. Sign up at https://brevo.com (free, no card).
#   2. Settings → Senders & IP → Senders → "Add a sender". Enter your
#      personal email (e.g. chaitanyagandi2000@gmail.com), click the
#      confirmation link Brevo emails you.
#   3. SMTP & API → API Keys → Generate a new API key. Paste below.
#   4. Set MAIL_FROM to "Display Name <verified-email>". The email part
#      MUST match the address you verified in step 2 or Brevo rejects
#      the send with "sender_not_valid".
BREVO_API_KEY=
MAIL_FROM=AuthShield <your-verified-email@gmail.com>
