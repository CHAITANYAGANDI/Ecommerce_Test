# Public URL of the API gateway (everything goes through here).
# Used as the base for /api/user/*, /api/amazon/products/*, /api/walmart/products/*.
REACT_APP_API_URL=http://localhost:7000

# Public URL of the Auth/server (only used by AuthRequest.js for the
# admin OAuth-like callback redirect).
REACT_APP_AUTH_URL=http://localhost:5000

# Public URL of this React app itself, used to build the callback URL
# returned to Auth/server during the admin client-authorization flow.
REACT_APP_CLIENT_URL=http://localhost:3001

# Public source-branded checkout pages.
REACT_APP_AMAZON_CHECKOUT_URL=http://localhost:8000/checkout
REACT_APP_WALMART_CHECKOUT_URL=http://localhost:8001/checkout
