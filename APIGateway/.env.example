PORT=7000

# Internal URLs of the upstream services.
USERS_SERVICE_URL=http://localhost:7001
AMAZON_SERVICE_URL=http://localhost:8000
WALMART_SERVICE_URL=http://127.0.0.1:8001

# URL of the Auth server. The gateway calls /auth/token/refresh here when an
# upstream provider rejects an expired JWT.
AUTH_SERVER_URL=http://localhost:5000

# Comma-separated list of allowed browser origins for CORS.
# Includes the source-branded mock storefronts (Amazon at :8000, Walmart at
# :8001) — after "Continue on X" redirects the buyer to those pages, they
# call back into this gateway to read the checkout intent and place orders,
# so their origins MUST be on the allowlist or the browser blocks the request.
CORS_ORIGINS=http://localhost:3001,http://localhost:8000,http://127.0.0.1:8001,http://localhost:8001

# MongoDB connection string. The gateway reads from the `creds` collection
# to inject `productsauthorization` headers when proxying product requests.
# Must point to the same DB as the Users service.
MONGO_CONN=mongodb://localhost:27017/your_db_name

# Asymmetric service-to-service auth (RFC 7523 JWT Bearer profile).
# The gateway signs a short-lived assertion JWT with its PRIVATE key. The
# auth server verifies it with the corresponding PUBLIC key. Compromising
# the auth server's env doesn't let an attacker mint tokens, because they
# can only verify — not sign — with the public key.
#
# Generate a fresh keypair with:
#   node -e "const {generateKeyPairSync}=require('crypto');const{publicKey,privateKey}=generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});console.log('PRIVATE:',JSON.stringify(privateKey).replace(/\"/g,''));console.log('PUBLIC:',JSON.stringify(publicKey).replace(/\"/g,''));"
#
# Paste the printed PRIVATE value here (a quoted single-line string with
# literal \n escapes — the gateway un-escapes them at startup) and paste the
# matching PUBLIC value into Auth/server/.env as GATEWAY_PUBLIC_KEY.
GATEWAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...REPLACE-WITH-YOUR-OWN-KEY...AQAB\n-----END PRIVATE KEY-----\n"

# How the gateway identifies itself in the JWT `iss` claim. Auth server
# matches this against its TRUSTED_ISSUERS list.
GATEWAY_ISSUER=apigateway

# Shared secret for service-to-service calls. Used as the x-internal-auth
# header on:
#  - DELETE /internal/token-cache/:apiName (Auth → Gateway invalidation)
#  - POST   /internal/snapshot-tracked     (GH Actions cron → Gateway)
#  - POST   Users /internal/price-drop     (Gateway → Users notifier)
# Must match the INTERNAL_AUTH_SECRET set in Auth/server and Users.
INTERNAL_AUTH_SECRET=replace-with-a-long-random-string

# Rate-limit tunables (optional — sensible defaults if omitted).
# Per-IP request budget across all gateway routes (default 120/min).
RATE_LIMIT_PER_MIN=120
# Per-IP request budget for /api/v1/user/auth/* and /api/v1/user/recovery/*
# (default 30 per 15 min).
AUTH_RATE_LIMIT_PER_15M=30

# Trust-proxy setting for express-rate-limit. `loopback` is correct for
# local dev. In prod set to the number of upstream proxies (Render/Heroku
# is typically 1). NEVER set to `true` — it lets clients spoof X-Forwarded-For.
TRUST_PROXY=loopback

# How long (ms) before the gateway re-snapshots a product's price on a
# product-detail read. Lower = more granular price-history chart, more
# DB writes. Higher = sparser history, cheaper writes. 6h default keeps
# storage bounded even for hot products while still capturing intraday
# moves.
SNAPSHOT_STALE_MS=21600000
